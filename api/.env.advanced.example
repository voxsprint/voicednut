# --- API Environment (Advanced Overrides) ------------------------------------
# This file is a reference for optional tuning.
# Do not load this file directly. Copy only the settings you need into `.env`.

# Legacy auth compatibility
# ADMIN_API_TOKEN=
# API_HMAC_SECRET=
API_HMAC_MAX_SKEW_MS=300000
STREAM_AUTH_SECRET=
STREAM_AUTH_MAX_SKEW_MS=300000

# Twilio runtime controls
TWILIO_GATHER_FALLBACK=true
TWILIO_WEBHOOK_VALIDATION=warn
TWILIO_MACHINE_DETECTION=Enable
# TWILIO_MACHINE_DETECTION_TIMEOUT=30
TWILIO_TTS_MAX_WAIT_MS=1200
TWILIO_FINAL_PROMPT_TTS_TIMEOUT_MS=6000
TWILIO_TTS_STRICT_PLAY=true
TWILIO_TTS_PREWARM_ENABLED=true

# AWS optional integrations
AWS_CONNECT_QUEUE_ID=
AWS_CONNECT_SOURCE_PHONE_NUMBER=
AWS_TRANSCRIPTS_QUEUE_URL=
AWS_EVENT_BUS_NAME=
AWS_WEBHOOK_VALIDATION=warn
AWS_WEBHOOK_SECRET=
AWS_POLLY_VOICE_ID=Joanna
AWS_POLLY_OUTPUT_BUCKET=
AWS_POLLY_OUTPUT_PREFIX=tts/
AWS_MEDIA_BUCKET=
AWS_PINPOINT_APPLICATION_ID=
AWS_PINPOINT_ORIGINATION_NUMBER=
AWS_PINPOINT_REGION=us-east-1
AWS_TRANSCRIBE_LANGUAGE_CODE=en-US
AWS_TRANSCRIBE_VOCABULARY_FILTER_NAME=

# Vonage advanced controls
VONAGE_ANSWER_URL=
VONAGE_EVENT_URL=
VONAGE_WEBSOCKET_CONTENT_TYPE=audio/l16;rate=16000
VONAGE_VOICE_REQUEST_TIMEOUT_MS=15000
VONAGE_VOICE_RETRY_ATTEMPTS=1
VONAGE_VOICE_CREATE_RETRY_ATTEMPTS=0
VONAGE_VOICE_RETRY_BASE_MS=250
VONAGE_VOICE_RETRY_MAX_DELAY_MS=2000
VONAGE_VOICE_RETRY_JITTER_MS=120
VONAGE_UUID_RECONCILE_INTERVAL_MS=120000
VONAGE_WEBHOOK_VALIDATION=warn
VONAGE_WEBHOOK_SIGNATURE_SECRET=
VONAGE_WEBHOOK_MAX_SKEW_MS=300000
VONAGE_WEBHOOK_REQUIRE_PAYLOAD_HASH=false
VONAGE_DTMF_WEBHOOK_ENABLED=false

# Server advanced controls
SERVER_REQUEST_TIMEOUT_MS=120000
SERVER_HEADERS_TIMEOUT_MS=65000
SERVER_KEEPALIVE_TIMEOUT_MS=5000
SERVER_MAX_REQUESTS_PER_SOCKET=0

# OpenRouter optional metadata
YOUR_SITE_URL=http://localhost:3000
YOUR_SITE_NAME=Voice Call Bot
# OPENROUTER_MAX_TOKENS=800

# Deepgram / Voice Agent advanced controls
VOICE_AGENT_CANARY_PERCENT=10
VOICE_AGENT_CANARY_SEED=voice_agent
VOICE_AGENT_FAILOVER_TO_LEGACY=true
VOICE_AGENT_OPEN_TIMEOUT_MS=8000
VOICE_AGENT_SETTINGS_TIMEOUT_MS=8000
VOICE_AGENT_IDLE_TIMEOUT_MS=12000
VOICE_AGENT_KEEPALIVE_MS=8000
VOICE_AGENT_NO_AUDIO_FALLBACK_MS=15000
VOICE_AGENT_MANAGED_THINK_ONLY=true
VOICE_AGENT_PARITY_CLOSE_ON_GOODBYE=true
VOICE_AGENT_LANGUAGE=en
VOICE_AGENT_LISTEN_MODEL=nova-2
VOICE_AGENT_SPEAK_MODEL=aura-2-andromeda-en
VOICE_AGENT_THINK_PROVIDER=open_ai
VOICE_AGENT_THINK_MODEL=gpt-4o-mini
# VOICE_AGENT_THINK_TEMPERATURE=0.2
VOICE_AGENT_LISTEN_SMART_FORMAT=true
VOICE_AGENT_LISTEN_KEYTERMS=
# Optional flow-to-voice map (JSON object)
# VOICE_AGENT_PROFILE_VOICE_MAP={"general":"aura-2-andromeda-en|aura-2-helena-en|aura-2-arcas-en","support":"aura-2-helena-en|aura-2-arcas-en","sales":"aura-2-aries-en|aura-2-andromeda-en","verification":"aura-2-thalia-en|aura-2-arcas-en","dating":"aura-2-helena-en|aura-2-arcas-en|aura-2-andromeda-en"}

VOICE_AGENT_STARTUP_TTS_PROBE_ENABLED=true
VOICE_AGENT_STARTUP_TTS_PROBE_TIMEOUT_MS=5000
VOICE_AGENT_SYNTHETIC_PROBE_TEXT=Hello, this is a quick voice quality probe.

VOICE_AGENT_CIRCUIT_BREAKER_ENABLED=true
VOICE_AGENT_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
VOICE_AGENT_CIRCUIT_BREAKER_WINDOW_MS=120000
VOICE_AGENT_CIRCUIT_BREAKER_COOLDOWN_MS=180000

VOICE_AGENT_AUTO_CANARY_ENABLED=true
VOICE_AGENT_AUTO_CANARY_INTERVAL_MS=60000
VOICE_AGENT_AUTO_CANARY_WINDOW_MS=300000
VOICE_AGENT_AUTO_CANARY_COOLDOWN_MS=180000
VOICE_AGENT_AUTO_CANARY_MIN_SAMPLES=8
VOICE_AGENT_AUTO_CANARY_MIN_PERCENT=5
VOICE_AGENT_AUTO_CANARY_MAX_PERCENT=50
VOICE_AGENT_AUTO_CANARY_STEP_UP_PERCENT=5
VOICE_AGENT_AUTO_CANARY_STEP_DOWN_PERCENT=10
