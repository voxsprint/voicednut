# --- API Environment (Minimal) ----------------------------------------------
# Keep this file lean. Advanced tuning knobs live in `.env.advanced.example`.

# Providers
CALL_PROVIDER=twilio
SMS_PROVIDER=twilio
EMAIL_PROVIDER=sendgrid

# Security
API_SECRET=change-me

# Server
PORT=3000
SERVER=
CORS_ORIGINS=

# --- Twilio (required when CALL_PROVIDER=twilio) ----------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
FROM_NUMBER=

# --- AWS (required when CALL_PROVIDER=aws) ----------------------------------
AWS_REGION=us-east-1
AWS_CONNECT_INSTANCE_ID=
AWS_CONNECT_CONTACT_FLOW_ID=

# --- Vonage (required when CALL_PROVIDER=vonage) ----------------------------
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_APPLICATION_ID=
VONAGE_PRIVATE_KEY=
VONAGE_VOICE_FROM_NUMBER=
VONAGE_SMS_FROM_NUMBER=

# --- AI Runtime ---------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
VOICE_MODEL=aura-2-andromeda-en

# Voice runtime mode
# legacy | hybrid | voice_agent
VOICE_RUNTIME_MODE=legacy
VOICE_AGENT_SECONDARY_ENABLED=false

# --- Telegram fallback (optional) --------------------------------------------
TELEGRAM_BOT_TOKEN=

# --- Telegram Mini App (Vercel deployment) -----------------------------------
# Set MINI_APP_URL to your deployed frontend URL and include it in CORS_ORIGINS.
MINI_APP_URL=https://voxly-miniapp.vercel.app
MINI_APP_SESSION_SECRET=
MINI_APP_SESSION_TTL_SECONDS=900
MINI_APP_INITDATA_MAX_AGE_SECONDS=300

# --- Common optional defaults -------------------------------------------------
DEFAULT_SMS_BUSINESS_ID=
CONFIG_COMPLIANCE_MODE=safe
RECORDING_ENABLED=false

# --- Where are advanced options? ---------------------------------------------
# Copy any needed overrides from:
#   api/.env.advanced.example
